# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Exactly two Telegram user IDs, comma separated (get yours from @userinfobot)
ALLOWED_TELEGRAM_IDS=111111111,222222222

# Optional: shared group chat id. Normally NOT needed — the bot auto-detects the
# group the first time you talk to it there and remembers it. Set to force one.
# GROUP_CHAT_ID=-1001234567890
# NOTE: for the bot to see free-text messages in the group, disable Group
# Privacy in @BotFather: /mybots -> Bot Settings -> Group Privacy -> Turn off.

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-5

# --- Database ---
# Used as-is inside docker compose; for local dev you can point at any Postgres
DATABASE_URL=postgresql+asyncpg://diyetisyen:diyetisyen@db:5432/diyetisyen
POSTGRES_USER=diyetisyen
POSTGRES_PASSWORD=diyetisyen
POSTGRES_DB=diyetisyen

# --- App ---
TZ=Europe/Istanbul
# Bearer token protecting the web dashboard + REST API. Choose a long random string.
DASHBOARD_TOKEN=change-me-to-a-long-random-string
LOG_LEVEL=INFO
